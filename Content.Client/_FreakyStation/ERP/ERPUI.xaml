<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:style="clr-namespace:Content.Client.Stylesheets"
               Title="{Loc 'erp-ui-title-self'}"
               SetWidth="560"
               MinWidth="560"
               SetHeight="840"
               MaxHeight="840"
               MinHeight="840"
               Resizable="false">
    <BoxContainer Name="BasedContainer"
                  Orientation="Vertical"
                  HorizontalExpand="True"
                  Margin="8">
        <TextureRect SetSize="544 52"
                     Stretch="KeepAspectCentered"
                     HorizontalAlignment="Center"
                     TexturePath="/Textures/_FreakStation/Casha/ERPicon/erproza.png"/>

        <BoxContainer Orientation="Horizontal"
                      HorizontalExpand="True"
                      Margin="0 8 0 8">
            <PanelContainer StyleClasses="AngleRect"
                            HorizontalExpand="True"
                            MinWidth="0">
                <BoxContainer Orientation="Vertical"
                              HorizontalExpand="True"
                              Margin="10 8 10 10">
                    <Label Name="UserCardHeading"
                           StyleClasses="StatusFieldTitle"
                           HorizontalExpand="True" />
                    <PanelContainer StyleClasses="LowDivider"
                                    SetHeight="2"
                                    Margin="0 6 0 8" />
                    <RichTextLabel Name="UserCardDetails"
                                   HorizontalExpand="True"
                                   VerticalExpand="True" />
                    <Label Text="{Loc 'erp-ui-arousal-label'}"
                           StyleClasses="StatusFieldTitle"
                           Margin="0 8 0 4" />
                    <ProgressBar Name="UserArousalBar"
                                 HorizontalExpand="True"
                                 MaxValue="1"
                                 MinValue="0"
                                 SetHeight="22">
                        <Label Name="UserArousalValue"
                               Margin="4 0" />
                    </ProgressBar>
                </BoxContainer>
            </PanelContainer>

            <controls:VSpacer Spacing="8" />

            <PanelContainer StyleClasses="AngleRect"
                            HorizontalExpand="True"
                            MinWidth="0">
                <BoxContainer Orientation="Vertical"
                              HorizontalExpand="True"
                              Margin="10 8 10 10">
                    <Label Name="TargetCardHeading"
                           StyleClasses="StatusFieldTitle"
                           HorizontalExpand="True" />
                    <PanelContainer StyleClasses="LowDivider"
                                    SetHeight="2"
                                    Margin="0 6 0 8" />
                    <RichTextLabel Name="TargetCardDetails"
                                   HorizontalExpand="True"
                                   VerticalExpand="True" />
                    <Label Text="{Loc 'erp-ui-arousal-label'}"
                           StyleClasses="StatusFieldTitle"
                           Margin="0 8 0 4" />
                    <ProgressBar Name="TargetArousalBar"
                                 HorizontalExpand="True"
                                 MaxValue="1"
                                 MinValue="0"
                                 SetHeight="22">
                        <Label Name="TargetArousalValue"
                               Margin="4 0" />
                    </ProgressBar>
                </BoxContainer>
            </PanelContainer>
        </BoxContainer>

        <BoxContainer Orientation="Horizontal"
                      Margin="2 0 2 8"
                      VerticalAlignment="Center">
            <RichTextLabel Name="CooldownLabel"
                           HorizontalExpand="True"
                           Visible="False" />
            <LineEdit Name="SearchBar"
                      PlaceHolder="{Loc 'erp-ui-search-placeholder'}"
                      HorizontalExpand="True"
                      Margin="8 0 0 0"
                      Access="Public" />
        </BoxContainer>

        <controls:HLine Color="{x:Static style:StyleNano.ButtonColorDefault}"
                        Thickness="2"
                        Access="Public" />

        <ItemList Name="ItemInteractions"
                  Access="Public"
                  SizeFlagsStretchRatio="8"
                  VerticalExpand="True"
                  ItemSeparation="2"
                  Margin="4 8 4 0"
                  SelectMode="Button"
                  StyleClasses="ItemList" />
    </BoxContainer>
</DefaultWindow>
