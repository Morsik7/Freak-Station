<controls:FancyWindow xmlns="https://spacestation14.io"
            xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
            xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
            Title="{Loc 'item-colorizer-window-title'}"
            MinSize="320 260">
    <BoxContainer Orientation="Vertical" Margin="8 8" SeparationOverride="6">
        <PanelContainer>
            <PanelContainer.PanelOverride>
                <gfx:StyleBoxFlat BackgroundColor="#1B1B1E" />
            </PanelContainer.PanelOverride>
            <BoxContainer Orientation="Vertical" Margin="6 6">
                <Label Text="{Loc 'item-colorizer-window-selected-item'}" />
                <Label Name="SelectedItemLabel" Access="Public" Text="{Loc 'item-colorizer-window-no-item'}" />
            </BoxContainer>
        </PanelContainer>
        <ColorSelectorSliders Name="ColorPicker" Access="Public" />
        <Button Name="ApplyButton"
                Access="Public"
                Text="{Loc 'item-colorizer-window-apply'}"
                HorizontalAlignment="Center"
                MinSize="140 32" />
    </BoxContainer>
</controls:FancyWindow>
